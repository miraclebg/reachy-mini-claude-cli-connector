# Copy to .env and adjust. All values are optional.

# --- Mac connector server (POST /chat) ---
# On the Pi, set this to the Mac's LAN IP.
CONNECTOR_URL=http://localhost:8080
# REQUEST_TIMEOUT_S=180
# Must match server/.env CONNECTOR_TOKEN (leave empty only if the connector has auth off).
# CONNECTOR_TOKEN=

# --- backend ---
# local = Mac mic/speaker (testing); reachy = the robot SDK.
REACHY_BACKEND=local
# REACHY_MEDIA_BACKEND=default     # default | local | webrtc (robot only)

# --- audio capture ---
# SAMPLE_RATE=16000
# FRAME_MS=30
# MAX_UTTERANCE_S=15

# --- end-of-speech (wake-word path only; button uses release) ---
# VAD_SILENCE_MS=800
# VAD_RMS_THRESHOLD=0.015
# VAD_MIN_SPEECH_MS=300

# --- phone hold-to-talk page ---
# BUTTON_ENABLED=true
# BUTTON_HOST=0.0.0.0
# BUTTON_PORT=8081
# Protects the phone page + status/history. Open it as http://<host>:8081/?token=<this>.
# Empty = no auth (the conversation history is readable by anyone on the LAN).
# BUTTON_TOKEN=

# --- settings-page IP guard (POST /servers/select|add|rescan on :8042) ---
# Comma-separated IPs/CIDRs allowed to change which connector the robot is bound to.
# Empty = open (a warning is logged at startup). Loopback and the currently-bound
# connector's host are always allowed, regardless of this setting.
# Setting this AFTER running open will drop any saved server whose host isn't
# permitted (it parks; re-select from an allowed host or from the robot itself
# over loopback).
# SETTINGS_ALLOW=

# --- wake word ("Hey Reachy") — inactive until BOTH are set ---
# WAKEWORD_ENABLED=true
# PICOVOICE_ACCESS_KEY=your-picovoice-access-key
# PORCUPINE_KEYWORD_PATH=/path/to/Hey-Reachy_en_mac.ppn
# PORCUPINE_SENSITIVITY=0.5

# LOG_LEVEL=INFO
