# Copy to .env and adjust. All values are optional.

# --- Mac connector server (POST /chat) ---
# On the Pi, set this to the Mac's LAN IP.
CONNECTOR_URL=http://localhost:8080
# REQUEST_TIMEOUT_S=180

# --- backend ---
# local = Mac mic/speaker (testing); reachy = the robot SDK.
REACHY_BACKEND=local
# REACHY_MEDIA_BACKEND=default     # default | local | webrtc (robot only)

# --- audio capture ---
# SAMPLE_RATE=16000
# FRAME_MS=30
# MAX_UTTERANCE_S=15

# --- end-of-speech (wake-word path only; button uses release) ---
# VAD_SILENCE_MS=800
# VAD_RMS_THRESHOLD=0.015
# VAD_MIN_SPEECH_MS=300

# --- phone hold-to-talk page ---
# BUTTON_ENABLED=true
# BUTTON_HOST=0.0.0.0
# BUTTON_PORT=8081

# --- wake word ("Hey Reachy") — inactive until BOTH are set ---
# WAKEWORD_ENABLED=true
# PICOVOICE_ACCESS_KEY=your-picovoice-access-key
# PORCUPINE_KEYWORD_PATH=/path/to/Hey-Reachy_en_mac.ppn
# PORCUPINE_SENSITIVITY=0.5

# LOG_LEVEL=INFO
