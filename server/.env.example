# Copy to .env and adjust. All values are optional except PIPER_MODEL (for audio).

# --- server ---
HOST=0.0.0.0
PORT=8080
# STRONGLY RECOMMENDED: shared secret required on all endpoints except /health.
# Without it, anyone who can reach this port can drive Claude (which runs with
# command-execution permissions). Generate one: python -c "import secrets;print(secrets.token_urlsafe(24))"
# Must match reachy_app/.env CONNECTOR_TOKEN.
# CONNECTOR_TOKEN=

# --- Claude CLI ---
# CLAUDE_BIN=claude
# CLAUDE_WORKING_DIR=/Users/mkovachev/sworkspace/reachi-min/claude-cli-connector/claude-workspace
# CLAUDE_MODEL=            # alias (opus|sonnet|haiku|fable) or full id; empty = CLI default
# CLAUDE_EFFORT=           # low|medium|high|xhigh|max; empty = CLI default.
                           # lower = snappier voice replies, higher = more thinking.
# CLAUDE_TIMEOUT_S=120

# Permission mode: auto = auto-approve tools (command execution + edits ON), deny
# list still blocks. dontAsk = read-only posture (deny anything not allowed below).
# CLAUDE_PERMISSION_MODE=auto
# Hard allow-list even under `auto` (unlisted tools are blocked). Bash is needed to
# run shell commands; Edit/Write to change files. Trim to read-only + use dontAsk.
# CLAUDE_ALLOWED_TOOLS=Read,Edit,Write,Glob,Grep,Bash,WebSearch,WebFetch
# Deny list ALWAYS wins (even under auto) — this is the main guardrail.
# CLAUDE_DISALLOWED_TOOLS=Bash(rm *),Bash(sudo *),Bash(curl *),Bash(wget *),Bash(git push *)
# CLAUDE_MAX_TURNS=6

# --- STT (faster-whisper) ---
# WHISPER_MODEL=base.en    # try small.en for better accuracy
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE=int8

# --- TTS (Piper) ---
# REQUIRED for /chat audio: absolute path to a Piper .onnx voice
PIPER_MODEL=/Users/mkovachev/sworkspace/reachi-min/claude-cli-connector/voices/en_US-lessac-medium.onnx
